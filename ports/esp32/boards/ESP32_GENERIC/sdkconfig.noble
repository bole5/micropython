# Disable the entire Bluetooth stack in ESP-IDF
CONFIG_BT_ENABLED=n
CONFIG_BT_NIMBLE_ENABLED=n
CONFIG_BTDM_CTRL_MODE_NBLE=n
CONFIG_BT_BLUEDROID_ENABLED=n

# --- USB (not needed, saves ~50KB flash) ---
CONFIG_ESP_CONSOLE_USB_CDC=n
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=n

# --- IPv6 (use IPv4) ---
CONFIG_LWIP_IPV6=n

# --- mDNS (not used) ---
CONFIG_MDNS_ENABLED=n

# --- WPA3 enterprise (home WiFi only) ---
CONFIG_ESP_WIFI_ENTERPRISE_SUPPORT=n

# Keep TLS client support (needed for weather forecast HTTPS)
CONFIG_ESP_TLS_USING_MBEDTLS=y
CONFIG_MBEDTLS_TLS_CLIENT_ONLY=y    # client only, no server TLS stack

# Strip the large built-in certificate bundle (~100KB) —
# your app skips cert validation anyway
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=n
CONFIG_ESP_TLS_INSECURE=y
CONFIG_ESP_TLS_SKIP_SERVER_CERT_VERIFY=y

# Disable server-side TLS (you serve plain HTTP via TinyServer)
CONFIG_MBEDTLS_TLS_SERVER=n

# Remove cipher suites you don't need
CONFIG_MBEDTLS_RC4_DISABLED=y
CONFIG_MBEDTLS_3DES_DISABLED=y

# --- Console: switch to UART only (saves RAM) ---
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
